    {
      "name": "budgets",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"budgets\" (\"id\" TEXT NOT NULL, \"name\" TEXT NOT NULL, \"currency_code\" TEXT NOT NULL, \"currency_decimal_digits\" INTEGER NOT NULL, \"date_format\" TEXT NOT NULL, \"created_at\" TEXT NOT NULL, \"updated_at\" TEXT NOT NULL, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "accounts",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"accounts\" (\"id\" TEXT NOT NULL, \"budget_id\" TEXT NOT NULL REFERENCES budgets (id), \"name\" TEXT NOT NULL, \"type\" TEXT NOT NULL, \"on_budget\" INTEGER NOT NULL CHECK (\"on_budget\" IN (0, 1)), \"closed\" INTEGER NOT NULL CHECK (\"closed\" IN (0, 1)), \"note\" TEXT NULL, \"sort_order\" INTEGER NOT NULL, \"created_at\" TEXT NOT NULL, \"updated_at\" TEXT NOT NULL, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "category_groups",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"category_groups\" (\"id\" TEXT NOT NULL, \"budget_id\" TEXT NOT NULL, \"name\" TEXT NOT NULL, \"hidden\" INTEGER NOT NULL CHECK (\"hidden\" IN (0, 1)), \"sort_order\" INTEGER NOT NULL, \"system_type\" TEXT NULL, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "categories",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"categories\" (\"id\" TEXT NOT NULL, \"group_id\" TEXT NOT NULL REFERENCES category_groups (id), \"name\" TEXT NOT NULL, \"hidden\" INTEGER NOT NULL CHECK (\"hidden\" IN (0, 1)), \"note\" TEXT NULL, \"sort_order\" INTEGER NOT NULL, \"linked_account_id\" TEXT NULL REFERENCES accounts (id), \"created_at\" TEXT NOT NULL, \"updated_at\" TEXT NOT NULL, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "category_budgets",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"category_budgets\" (\"id\" TEXT NOT NULL, \"category_id\" TEXT NOT NULL REFERENCES categories (id), \"month\" TEXT NOT NULL, \"assigned\" INTEGER NOT NULL, \"created_at\" TEXT NOT NULL, \"updated_at\" TEXT NOT NULL, PRIMARY KEY (\"id\"), UNIQUE (\"category_id\", \"month\"));"
        }
      ]
    },
    {
      "name": "targets",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"targets\" (\"id\" TEXT NOT NULL, \"category_id\" TEXT NOT NULL REFERENCES categories (id), \"type\" TEXT NOT NULL, \"amount\" INTEGER NOT NULL, \"target_month\" TEXT NULL, \"created_at\" TEXT NOT NULL, \"updated_at\" TEXT NOT NULL, PRIMARY KEY (\"id\"), UNIQUE (\"category_id\"));"
        }
      ]
    },
    {
      "name": "payees",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"payees\" (\"id\" TEXT NOT NULL, \"budget_id\" TEXT NOT NULL, \"name\" TEXT NOT NULL, \"default_category_id\" TEXT NULL REFERENCES categories (id), \"transfer_account_id\" TEXT NULL REFERENCES accounts (id), PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "settings",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"settings\" (\"key\" TEXT NOT NULL, \"value\" TEXT NOT NULL, PRIMARY KEY (\"key\"));"
        }
      ]
    },
    {
      "name": "scheduled_transactions",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"scheduled_transactions\" (\"id\" TEXT NOT NULL, \"account_id\" TEXT NOT NULL REFERENCES accounts (id), \"amount\" INTEGER NOT NULL, \"payee_id\" TEXT NULL REFERENCES payees (id), \"category_id\" TEXT NULL REFERENCES categories (id), \"memo\" TEXT NULL, \"frequency\" TEXT NOT NULL, \"next_date\" TEXT NOT NULL, \"created_at\" TEXT NOT NULL, \"updated_at\" TEXT NOT NULL, PRIMARY KEY (\"id\"));"
        }
      ]
