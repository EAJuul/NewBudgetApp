      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"transactions\" (\"id\" TEXT NOT NULL, \"account_id\" TEXT NOT NULL REFERENCES accounts (id), \"date\" TEXT NOT NULL, \"amount\" INTEGER NOT NULL, \"payee_id\" TEXT NULL REFERENCES payees (id), \"category_id\" TEXT NULL REFERENCES categories (id), \"memo\" TEXT NULL, \"cleared\" TEXT NOT NULL, \"approved\" INTEGER NOT NULL CHECK (\"approved\" IN (0, 1)), \"flag_color\" TEXT NULL, \"transfer_transaction_id\" TEXT NULL REFERENCES transactions (id), \"transfer_account_id\" TEXT NULL REFERENCES accounts (id), \"scheduled_transaction_id\" TEXT NULL REFERENCES scheduled_transactions (id), \"import_id\" TEXT NULL, \"is_split\" INTEGER NOT NULL CHECK (\"is_split\" IN (0, 1)), \"deleted\" INTEGER NOT NULL CHECK (\"deleted\" IN (0, 1)), \"created_at\" TEXT NOT NULL, \"updated_at\" TEXT NOT NULL, PRIMARY KEY (\"id\"));"
